    - target: {fileID: 4025412338875227900, guid: 290398d187196b64cb4209240975f003, type: 3}
      propertyPath: m_text
      value: "Mroczna scena ukazuje \u015Bwiat pogr\u0105\u017Cony w rozpadzie, gdzie
        groteskowe postacie otaczaj\u0105 kobiet\u0119 zatracon\u0105 mi\u0119dzy
        cierpieniem a ob\u0142\u0119dem. Ci\u0119\u017Cka, niemal brudna kolorystyka
        oraz ekspresyjna faktura farby wzmacniaj\u0105 poczucie niepokoju i beznadziei.
        Obraz mo\u017Cna odczytywa\u0107 jako wizj\u0119 ludzkich l\u0119k\xF3w,
        winy oraz upadku cywilizacji."
      objectReference: {fileID: 0}
