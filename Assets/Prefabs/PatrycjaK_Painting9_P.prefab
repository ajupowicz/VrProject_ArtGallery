    - target: {fileID: 2175362557898730303, guid: a2bfe8411690b294880752a5e623bb96, type: 3}
      propertyPath: m_text
      value: "Obraz przedstawia mitycznego kitsune ukrytego po\u015Br\xF3d wilgotnego,
        bambusowego lasu. Przygaszone, pastelowe barwy oraz mi\u0119kkie poci\u0105gni\u0119cia
        farby tworz\u0105 atmosfer\u0119 ciszy, tajemnicy i duchowej harmonii. Delikatnie
        widoczny \u0142uk torii w tle sugeruje obecno\u015B\u0107 \u015Bwiata pomi\u0119dzy
        rzeczywisto\u015Bci\u0105 a japo\u0144sk\u0105 legend\u0105.Dzie\u0142o symbolizuje
        natur\u0119 jako miejsce spokoju, ale r\xF3wnie\u017C ukrytej si\u0142y i
        dawnych wierze\u0144."
      objectReference: {fileID: 0}
