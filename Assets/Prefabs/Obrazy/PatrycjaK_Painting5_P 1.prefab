    - target: {fileID: 8335825389890226126, guid: f7a8918a29a180b45ad1267ee486aec1, type: 3}
      propertyPath: m_text
      value: "Surrealistyczna kompozycja przedstawia dwie z\u0142\u0105czone twarze
        pr\xF3buj\u0105ce uwolni\u0107 si\u0119 od siebie nawzajem. Ekspresyjne,
        ci\u0119\u017Ckie poci\u0105gni\u0119cia farby oraz ciemna kolorystyka buduj\u0105
        atmosfer\u0119 cierpienia, wewn\u0119trznego konfliktu i utraty to\u017Csamo\u015Bci.
        Obraz symbolizuje walk\u0119 cz\u0142owieka z w\u0142asnymi emocjami, l\u0119kami
        oraz drug\u0105 stron\u0105 w\u0142asnej natury."
      objectReference: {fileID: 0}
