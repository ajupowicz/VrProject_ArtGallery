    - target: {fileID: 8335825389890226126, guid: f7a8918a29a180b45ad1267ee486aec1, type: 3}
      propertyPath: m_text
      value: "Studium nieobecno\u015Bci. Pod ci\u0119\u017Ck\u0105, g\u0142\u0119bok\u0105
        zieleni\u0105 materia\u0142u kryje si\u0119 nieznana forma \u2013 mo\u017Ce
        cz\u0142owiek, mo\u017Ce pos\u0105g, a mo\u017Ce co\u015B, co dopiero czeka
        na przebudzenie. Monochromatyczna paleta barw i monumentalne fa\u0142dy tkaniny
        buduj\u0105 g\u0119st\u0105, klaustrofobiczn\u0105 atmosfer\u0119 tajemnicy,
        kt\xF3ra zdaje si\u0119 obserwowa\u0107 gracza z ciemno\u015Bci."
      objectReference: {fileID: 0}
