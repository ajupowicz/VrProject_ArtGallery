    - target: {fileID: 8335825389890226126, guid: f7a8918a29a180b45ad1267ee486aec1, type: 3}
      propertyPath: m_text
      value: "Obraz przedstawia tajemnicz\u0105 kobiet\u0119 trzymaj\u0105c\u0105
        w d\u0142oni wyrwane serce - symbol utraty, po\u015Bwi\u0119cenia i emocjonalnego
        b\xF3lu. Dzie\u0142o nie pokazuje dos\u0142ownej przemocy, lecz emocjonalny
        ci\u0119\u017Car zwi\u0105zany z mi\u0142o\u015Bci\u0105, strat\u0105 i oddaniem
        siebie drugiemu cz\u0142owiekowi. Ka\u017Cdy element kompozycji pozostawia
        widzowi przestrze\u0144 do w\u0142asnej interpretacji uczu\u0107 ukrytych
        za spojrzeniem bohaterki."
      objectReference: {fileID: 0}
